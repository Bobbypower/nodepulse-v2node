+type rotatingLogWriter struct {
+	path      string
+	maxSize   int64
+	maxBackup int
+	file      *os.File
+}
+
+func newRotatingLogWriter(path string, maxSizeMB int, maxBackups int) (*rotatingLogWriter, error) {
+	if maxSizeMB <= 0 {
+		maxSizeMB = 100
+	}
+	if maxBackups <= 0 {
+		maxBackups = 3
+	}
+	writer := &rotatingLogWriter{
+		path:      path,
+		maxSize:   int64(maxSizeMB) * 1024 * 1024,
+		maxBackup: maxBackups,
+	}
+	return writer, writer.open()
+}
+
+func (w *rotatingLogWriter) open() error {
+	file, err := os.OpenFile(w.path, os.O_CREATE|os.O_WRONLY|os.O_APPEND, 0644)
+	if err != nil {
+		return err
+	}
+	w.file = file
+	return nil
+}
+
+func (w *rotatingLogWriter) Write(p []byte) (int, error) {
+	if w.file == nil {
+		if err := w.open(); err != nil {
+			return 0, err
+		}
+	}
+	if info, err := w.file.Stat(); err == nil && info.Size()+int64(len(p)) > w.maxSize {
+		if err := w.rotate(); err != nil {
+			return 0, err
+		}
+	}
+	return w.file.Write(p)
+}
+
+func (w *rotatingLogWriter) Close() error {
+	if w.file == nil {
+		return nil
+	}
+	return w.file.Close()
+}
+
+func (w *rotatingLogWriter) rotate() error {
+	if w.file != nil {
+		_ = w.file.Close()
+		w.file = nil
+	}
+	for i := w.maxBackup - 1; i >= 1; i-- {
+		oldPath := fmt.Sprintf("%s.%d", w.path, i)
+		newPath := fmt.Sprintf("%s.%d", w.path, i+1)
+		if _, err := os.Stat(oldPath); err == nil {
+			_ = os.Rename(oldPath, newPath)
+		}
+	}
+	if _, err := os.Stat(w.path); err == nil {
+		_ = os.Rename(w.path, fmt.Sprintf("%s.1", w.path))
+	}
+	return w.open()
+}
+
+func configureLogOutput(logConfig conf.LogConfig) io.Closer {
+	if logConfig.Output == "" {
+		return nil
+	}
+	writer, err := newRotatingLogWriter(logConfig.Output, logConfig.MaxSizeMB, logConfig.MaxBackups)
+	if err != nil {
+		log.WithField("err", err).Error("Open log file failed, using stdout instead")
+		return nil
+	}
+	log.SetOutput(writer)
+	return writer
+}
